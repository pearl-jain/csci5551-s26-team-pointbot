<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="MainTree">
  <BehaviorTree ID="ActionTree">
    <Sequence>
      <LogString message="Determine target"/>
      <MoveObject object_pose="{object_pose}"
                  goal_pose="{goal_pose}"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="MainTree">
    <Sequence>
      <Inverter>
        <KeepRunningUntilFailure>
          <Sequence>
            <RetryUntilSuccessful num_attempts="-1">
              <DetectObject object_pose="{object_pose}"/>
            </RetryUntilSuccessful>
            <Sleep msec="3000"/>
            <RetryUntilSuccessful num_attempts="-1">
              <DetectGoal goal_pose="{goal_pose}"/>
            </RetryUntilSuccessful>
            <MoveObject object_pose="{object_pose}"
                        goal_pose="{goal_pose}"/>
          </Sequence>
        </KeepRunningUntilFailure>
      </Inverter>
      <LogString message="Home the Robot, it failed, or perform recovery."/>
      <AlwaysFailure/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="DetectGoal"
            editable="true">
      <output_port name="goal_pose"/>
    </Action>
    <Action ID="DetectObject"
            editable="true">
      <output_port name="object_pose"/>
    </Action>
    <Action ID="LogString"
            editable="true">
      <input_port name="message"/>
    </Action>
    <Action ID="MoveObject"
            editable="true">
      <input_port name="object_pose"/>
      <input_port name="goal_pose"/>
    </Action>
  </TreeNodesModel>

</root>
