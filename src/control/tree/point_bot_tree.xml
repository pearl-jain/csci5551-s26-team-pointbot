<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence>
      <Inverter>
        <KeepRunningUntilFailure>
          <Sequence>
            <RetryUntilSuccessful num_attempts="-1">
              <DetectObject object_pose="{object_pose}"/>
            </RetryUntilSuccessful>
            <Inverter>
              <KeepRunningUntilFailure>
                <Sequence>
                  <Parallel failure_count="1"
                            success_count="-1">
                    <MoveObject pose="{object_pose}"
                                task="pickup"/>
                    <RetryUntilSuccessful num_attempts="-1">
                      <DetectGoal goal_pose="{goal_pose}"/>
                    </RetryUntilSuccessful>
                  </Parallel>
                  <MoveObject pose="{goal_pose}"
                              task="place"/>
                  <Fallback>
                    <Timeout msec="10000">
                      <RetryUntilSuccessful num_attempts="-1">
                        <DetectObject object_pose="{object_pose}"/>
                      </RetryUntilSuccessful>
                    </Timeout>
                    <Inverter>
                      <MoveObject pose="{object_pose}"
                                  task="home"/>
                    </Inverter>
                  </Fallback>
                </Sequence>
              </KeepRunningUntilFailure>
            </Inverter>
          </Sequence>
        </KeepRunningUntilFailure>
      </Inverter>
      <MoveObject pose="{object_pose}"
                  task="home"/>
      <AlwaysFailure/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="DetectGoal"
            editable="true">
      <output_port name="goal_pose"/>
    </Action>
    <Action ID="DetectObject"
            editable="true">
      <output_port name="object_pose"/>
    </Action>
    <Action ID="MoveObject"
            editable="true">
      <input_port name="pose"/>
      <input_port name="task"/>
    </Action>
  </TreeNodesModel>

</root>
